# ── LLM + Embeddings ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Document Parsing ──────────────────────────────────────────
# Get free key at: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=llx-...

# ── Reranker ──────────────────────────────────────────────────
# Get free key at: https://dashboard.cohere.com
COHERE_API_KEY=...

# ── Vector Database ───────────────────────────────────────────
# Local Docker (default): http://localhost:6333
# Qdrant Cloud: https://<cluster-id>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                  # leave blank for local Docker
QDRANT_COLLECTION_NAME=company_docs

# ── Observability ─────────────────────────────────────────────
# Get free key at: https://smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rag-internal-docs

# ── Auth / JWT ────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480     # 8 hours

# Demo user passwords are all "secret" — change in production or replace
# the _DEMO_USERS dict in auth/jwt_handler.py with real DB/IdP lookups.

# ── Event-driven ingestion ─────────────────────────────────────
# Redis job queue (used by ARQ worker)
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_S=30

# ── Webhook HMAC secrets ───────────────────────────────────────
# Copy the value you set in each provider's webhook configuration UI.
# Leave blank to skip signature verification (local dev only).
#
# Confluence: Settings → System → Webhooks → Secret
WEBHOOK_SECRET_CONFLUENCE=
# SharePoint: Subscription clientState value (treat as shared secret)
WEBHOOK_SECRET_SHAREPOINT=
# Google Drive: Push notification channel token
WEBHOOK_SECRET_GDRIVE=

# ── App Settings ──────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
TOP_K_RETRIEVAL=10          # candidates fetched from vector store
TOP_N_RERANK=3              # docs kept after reranking
HYBRID_ALPHA=0.5            # 0 = pure BM25, 1 = pure vector
CHUNK_SIZES=2048,512,128    # parent,child,leaf node sizes

# ── Multimodal processing ──────────────────────────────────────
# Set to false to skip table + image processing (saves API cost)
ENABLE_MULTIMODAL=true
# Model for VLM calls (must support vision). gpt-4o-mini is cheaper.
VLM_MODEL=gpt-4o-mini
# Max chars of surrounding text sent to VLM as context
MULTIMODAL_CONTEXT_WINDOW=500
# Images larger than this many MB are skipped
MULTIMODAL_MAX_IMAGE_MB=4.0

# ── Agentic router ────────────────────────────────────────────────
# Fast cheap model for intent classification (adds ~100ms per query)
ROUTER_MODEL=gpt-4o-mini
# How many previous turns to include in conversation context
CONVERSATION_MEMORY_TURNS=6
# Max concurrent sessions kept in memory
CONVERSATION_MAX_SESSIONS=1000

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
